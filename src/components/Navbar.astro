---
interface Props {
  page?: 'home' | 'case';
}
const { page = 'home' } = Astro.props;
---

<header class="minibar">
  <div class="minibar-inner">
    <a class="brand" href="index.html"><img class="deer" src="assets/brand-2.svg" alt="Amber deer mark">Amber</a>
    <a class="mlink" href="index.html#team">Team</a>
    <a class="mlink" href="case.html">Case Study</a>
    <a class="mlink ghost" href="https://github.com/amber-runtime/amber" target="_blank" rel="noopener">
      <svg class="gh" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      GitHub
    </a>
    {page === 'case' && <span class="now"><b>Introduction</b></span>}
  </div>
</header>

<style is:global>
  .minibar{position:sticky;top:0;z-index:50;display:flex;align-items:center;
    height:64px;padding:0 max(40px, calc((100% - 1180px)/2 + 40px));
    background:rgba(9,9,11,.72);backdrop-filter:blur(12px);border-bottom:1px solid var(--line-soft)}
  .minibar-inner{width:100%;display:flex;align-items:center;gap:16px}
  .brand{display:inline-flex;align-items:center;gap:10px;font-family:var(--display);
    font-weight:600;font-size:20px;letter-spacing:-.02em;color:var(--amber);text-decoration:none}
  .brand .deer{height:36px;width:auto;display:block;flex:none}
  .minibar .mlink{font-family:var(--mono);font-size:15px;letter-spacing:.04em;color:var(--mute);
    text-decoration:none;transition:color .18s;white-space:nowrap}
  .minibar .mlink:hover{color:var(--amber-lt)}
  .minibar .mlink.ghost{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--line-soft);
    border-radius:8px;padding:8px 13px;color:var(--bone-dim)}
  .minibar .mlink.ghost:hover{border-color:var(--line);color:var(--amber-lt)}
  .minibar .now{margin-left:auto;font-family:var(--mono);font-size:14px;letter-spacing:.12em;color:var(--faint)}
  .minibar .now b{color:var(--amber);font-weight:400}
  .gh{width:15px;height:15px;fill:currentColor;display:block}
</style>
