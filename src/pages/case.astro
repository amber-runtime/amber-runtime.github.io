---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import prefix from '../partials/case-prefix.html?raw';
import suffix from '../partials/case-suffix.html?raw';
import js from '../scripts/case.js?raw';
const title = 'Amber: durable execution for AI agents';;
const description = 'Amber is an open-source, self-hosted durable execution runtime for long-running AI agents.';;
const entries = (await getCollection('sections')).sort((a,b)=>a.data.order-b.data.order);
const sections = await Promise.all(entries.map(async e => ({ data:e.data, Content:(await render(e)).Content })));
---
<Base title={title} description={description}>
  <Fragment slot="head">
    <link rel="stylesheet" href={import.meta.env.BASE_URL + 'case.css'} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
  
  </Fragment>
  <Fragment set:html={prefix} />
  {sections.map(({ data, Content }) => (
    <section class="sec" id={data.id} data-screen-label={data.screenLabel}>
      <div class="secbody">
        <p class="eyebrow"><span class="sn">{data.num}</span> {data.label} <span class="ln"></span></p>
        <h2 class="dh">{data.title}</h2>
        <Content />
      </div>
    </section>
  ))}
  <Fragment set:html={suffix} />
  <script is:inline set:html={js} />
</Base>
